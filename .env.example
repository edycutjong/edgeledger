# EdgeLedger (OKX.AI edition) — copy to .env.local (gitignored) and fill in.
# See DEMO.md for the exact commands each of these unlocks.

# ── Data APIs (optional) ─────────────────────────────────────────────────────
# The build runs fully offline on fixtures/known-picks.json + fixtures/picks.csv
# without these — only needed if you want to re-pull live odds/fixtures.
# Get from: https://www.football-data.org/client/register
FOOTBALL_DATA_KEY=
# Get from: https://the-odds-api.com/#get-access
ODDS_API_KEY=

# ── OKX x402 payment rail ────────────────────────────────────────────────────
# Payment rail switch (ARCHITECTURE.md §Payment wiring). Only 'okx' is
# implemented in this Tier-1 build.
PAY_RAIL=okx

# x402 network (CAIP-2). Default is the rehearsal testnet; switch to the
# mainnet listing network when going live.
# Get from: config.ts NETWORKS map (eip155:1952 = X Layer Rehearsal,
# eip155:196 = X Layer mainnet)
X402_NETWORK=eip155:1952

# x402 receiver — address only, no private key (decoupled from the
# facilitator). This is the X Layer wallet address that receives the $0.05
# per-call payments.
# Get from: your own X Layer wallet (e.g. OKX Wallet) — do NOT reuse the
# placeholder below in production.
PAYTO_ADDRESS=0x45078eD96C2bB171009A47a57aF5C085Bf4fD0e3

# OKX Developer Portal facilitator credentials — required for REAL on-chain
# settlement. Leave BLANK for local dev/CI: api/rails/localFacilitator.ts is
# used instead — it verifies EIP-3009 signatures for real but honestly
# refuses to fabricate settlement (see that file's header comment).
# Get from: https://web3.okx.com/onchainos/dev-portal
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# ── Optional overrides ───────────────────────────────────────────────────────
# EDGELEDGER_PRICE_UNITS=50000     # $0.05 in atomic 6dp units
# EDGELEDGER_DECAY_HALFLIFE_MIN=30
# PORT=8403
# EDGELEDGER_API_URL=http://localhost:8403
