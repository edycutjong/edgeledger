{
  "name": "edgeledger-okx",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "EdgeLedger (OKX.AI edition) \u2014 the agent that rejects your bet. Pay-per-call World Cup bet validation over OKX x402 on X Layer + a free, loss-inclusive public ledger.",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "start": "tsx api/server.ts",
    "api": "tsx api/server.ts",
    "settle": "tsx scripts/settle.ts",
    "bench": "tsx scripts/bench.ts",
    "readiness": "tsx scripts/check_submission_readiness.ts",
    "audit": "tsx scripts/audit.ts",
    "paid-smoke": "tsx scripts/paid-call-smoke.ts",
    "snapshot": "tsx data/snapshot.ts",
    "anchor": "tsx scripts/anchor.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --silent",
    "ci": "npm run lint && npm run typecheck && npm run test:coverage"
